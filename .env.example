# ── Syncfox runtime config ────────────────────────────────────────────
# Copy to `.env` and fill in. Anything not set here uses the defaults
# baked into src/cloud_sync/config.py.

# Public URL operator's reverse-proxy (Caddy/nginx/Cloudflare-tunnel/etc.)
# fronts. Used to construct OAuth callback URLs. localhost works for
# fully local-only setups.
PUBLIC_BASE_URL=http://localhost:8081

# Logging
ENV=local
LOG_LEVEL=INFO
DATA_DIR=/data

# ── Google Drive provider (optional) ──────────────────────────────────
# Created at https://console.cloud.google.com/apis/credentials. Pick
# "Desktop app" (or "Web app" with the redirect URL below). Leave blank
# if you only sync iCloud/Dropbox/etc.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Defaults to "$PUBLIC_BASE_URL/remotes/oauth/callback/google" if blank.
GOOGLE_OAUTH_REDIRECT_URL=

# ── Dropbox provider (optional, lands in Phase 5) ─────────────────────
DROPBOX_OAUTH_CLIENT_ID=
DROPBOX_OAUTH_CLIENT_SECRET=
DROPBOX_OAUTH_REDIRECT_URL=

# ── Credential-at-rest encryption (opt-in) ────────────────────────────
# When set, all newly-stored provider credentials are Fernet-encrypted
# (PBKDF2-SHA256, 200k rounds, static app salt). Existing plaintext
# blobs continue to decrypt fine. NO RECOVERY if you lose this — back it
# up in your password manager BEFORE setting it. Leave blank to keep
# storing credentials in plaintext (default).
SYNCFOX_MASTER_PASSWORD=
# Legacy alias accepted for back-compat with installs that pre-date the
# Phase 4 rename. Set EITHER one, not both.
AGE_SECRET_KEY=

# ── Daily expiry-nudge thresholds (operator-tunable, Phase 1) ─────────
# Badge colour breakpoints for the days-remaining surface on /remotes.
SYNCFOX_BADGE_ORANGE_DAYS=5
SYNCFOX_BADGE_RED_DAYS=2
# Discord webhook fired daily for any remote ≤ this threshold. No-op if
# unset (UI badge becomes the only nudge).
SYNCFOX_NUDGE_DAYS=25
SYNCFOX_DISCORD_WEBHOOK_URL=
SYNCFOX_NUDGE_LOCAL_TZ=America/Edmonton
SYNCFOX_NUDGE_LOCAL_HOUR=9

# ── Optional: Vaultwarden / Bitwarden secrets backend (Phase 2) ───────
# If set, Syncfox tries to read selected secrets (Apple ID password,
# OAuth client secrets, etc.) from a Vaultwarden item at startup,
# falling back to the values above when not. Leave blank to use plain
# .env only.
VAULTWARDEN_URL=
VAULTWARDEN_ITEM_ID=
VAULTWARDEN_EMAIL=
VAULTWARDEN_MASTER_PASSWORD=

# ── Reverse-proxy basic auth (informational only) ─────────────────────
# Syncfox itself doesn't enforce auth — it expects a reverse-proxy
# (Caddy / nginx / Authelia / etc.) in front. See README for examples.
